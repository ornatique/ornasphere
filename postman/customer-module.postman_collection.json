    "item":  [
                 {
                     "name":  "Auth - Login",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Accept",
                                                        "value":  "application/json"
                                                    },
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
                                              },
                                     "url":  "{{baseUrl}}/api/company/login"
                                 },
                     "response":  [

                                  ],
                     "event":  [
                                   {
                                       "script":  {
                                                      "exec":  [
                                                                   "const res = pm.response.json();",
                                                                   "if (res.user_id) { pm.collectionVariables.set(\"userId\", String(res.user_id)); pm.environment.set(\"userId\", String(res.user_id)); }"
                                                               ],
                                                      "type":  "text/javascript"
                                                  },
                                       "listen":  "test"
                                   }
                               ]
                 },
                 {
                     "name":  "Auth - Verify OTP",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Accept",
                                                        "value":  "application/json"
                                                    },
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"user_id\": {{userId}},\n  \"otp\": \"{{otp}}\"\n}"
                                              },
                                     "url":  "{{baseUrl}}/api/company/verify-otp"
                                 },
                     "response":  [

                                  ],
                     "event":  [
                                   {
                                       "script":  {
                                                      "exec":  [
                                                                   "const res = pm.response.json();",
                                                                   "if (res.token) { pm.collectionVariables.set(\"token\", res.token); pm.environment.set(\"token\", res.token); }"
                                                               ],
                                                      "type":  "text/javascript"
                                                  },
                                       "listen":  "test"
                                   }
                               ]
                 },
                 {
